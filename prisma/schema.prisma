generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  name     String?
  email    String @unique
  password String
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  techStack   String
  liveDemo    String?
  github      String?
  createdAt   DateTime @default(now())
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  startDate   String
  endDate     String?
  description String
  order       Int      @default(0)
}

model Education {
  id          String   @id @default(cuid())
  institute   String
  degree      String
  year        String
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  category    String?
  icon        String?
  level       Int?
}
